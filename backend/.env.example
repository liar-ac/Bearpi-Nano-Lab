DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=true
DJANGO_DEBUG_ALLOW_ANY_HOSTS=false
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,10.211.110.10
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://10.211.110.10:5173,http://10.211.110.10:5174,http://10.211.110.10:8000
CSRF_TRUSTED_ORIGINS=http://10.211.110.10:8000,http://10.211.110.10:5173,http://10.211.110.10:5174

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=bearpi_lab
MYSQL_USER=root
MYSQL_PASSWORD=password
DEVICE_INGEST_TOKEN=
DEVICE_TOKEN_SECRET=replace-me-device-token-secret
DEVICE_ACTIVE_TTL_SECONDS=45
REDIS_URL=redis://127.0.0.1:6379/0

HUAWEI_IOTDA_ENDPOINT=
HUAWEI_IOTDA_PROJECT_ID=

# AI 智能分析（小米 MiMo API, Anthropic 兼容格式）
# 不配置 XIAOMI_MIMO_API_KEY 时 AI 功能不可用，其他功能不受影响
XIAOMI_MIMO_API_URL=https://token-plan-cn.xiaomimimo.com/anthropic
XIAOMI_MIMO_API_KEY=your-api-key-here
XIAOMI_MIMO_MODEL=claude-3-5-sonnet-20241022
XIAOMI_MIMO_TIMEOUT=30
# 开发演示模式：AI接口失败时返回兜底提示，不显示502
AI_ENABLE_DEBUG_FALLBACK=true
